[flake8]
max-line-length = 88
exclude = [
    'venv',
    '.git',
    '__pycache__'
]
	
extend-ignore = 
    # E203, Whitespace before ':'
    E203, 
    # E402, Module level import not at top of file
    E402,
    # E704, Multiple statements on one line (def)
    E704
	
show-source = True
statistics = True
tee = True
